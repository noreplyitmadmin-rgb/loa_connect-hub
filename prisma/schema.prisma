generator client {
  provider = "prisma-client"
  output   = "../lib/generated"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         String   @default("STUDENT")
  departmentId String?
  course       String?
  isDisabled   Boolean  @default(false)
  hasLoggedInBefore Boolean @default(false)
  lastLoginAt       DateTime?
  createdAt    DateTime @default(now())

  department          Department?               @relation(fields: [departmentId], references: [id])
  deanDepartment      Department?               @relation("DeanDepartment")
  availabilityRules   FacultyAvailabilityRule[]
  studentAppointments Appointment[]             @relation("StudentAppointments")
  facultyAppointments Appointment[]             @relation("FacultyAppointments")
  appointmentAttendees AppointmentAttendee[]
  organizedMeetings   InternalMeeting[]         @relation("OrganizedMeetings")
  meetingParticipants InternalMeetingParticipant[]
  accounts            Account[]
  sessions            Session[]
}

model Department {
  id     String @id @default(cuid())
  name   String
  code   String @unique
  deanId String? @unique

  dean  User? @relation("DeanDepartment", fields: [deanId], references: [id])
  users User[]
}

model Appointment {
  id              String   @id @default(cuid())
  studentId       String
  facultyId       String
  sessionGroupId  String?
  date            String
  startTime       String
  endTime         String
  title           String?
  description     String?
  status          String   @default("PENDING")
  actionTaken     String?
  additionalRemarks String?
  teamsLink       String?
  teamsSyncStatus  String  @default("UNWRITTEN")
  teamsSyncRetries Int     @default(0)
  teamsSyncError   String?
  teamsSyncLastAttempt DateTime?
  requestedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student   User                  @relation("StudentAppointments", fields: [studentId], references: [id])
  faculty   User                  @relation("FacultyAppointments", fields: [facultyId], references: [id])
  attendees AppointmentAttendee[]
}

model AppointmentAttendee {
  id            String @id @default(cuid())
  appointmentId String
  userId        String
  status        String @default("INVITED")
  isMandatory   Boolean @default(true)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model InternalMeeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String
  startTime   String
  endTime     String
  organizerId String
  teamsEventId String?
  teamsLink   String?
  status      String   @default("CONFIRMED")
  createdAt   DateTime @default(now())

  organizer    User                          @relation("OrganizedMeetings", fields: [organizerId], references: [id])
  participants InternalMeetingParticipant[]
}

model InternalMeetingParticipant {
  id        String @id @default(cuid())
  meetingId String
  userId    String
  status    String @default("PENDING")

  meeting InternalMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model FacultyAvailabilityRule {
  id        String @id @default(cuid())
  facultyId String
  dayOfWeek Int
  isBlocked Boolean @default(false)
  startTime String?
  endTime   String?
  startDate String
  endDate   String?

  faculty User @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  @@unique([facultyId, dayOfWeek, startDate])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  action    String   // "LOGIN", "CREATE_USER", "DISABLE_USER", "ENABLE_USER", "CHANGE_ROLE", "PASSWORD_RESET", "ACTIVATE_USER"
  details   String?
  createdAt DateTime @default(now())
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
